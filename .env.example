# Bangladesh Financial Companion — Environment Variables
# Copy this file to .env.local (web) and .env (api) and fill in real values.
# NEVER commit real secrets to git.

# ─── Supabase (Postgres + pgvector) ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Direct Postgres connection (for Alembic / SQLAlchemy async)
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ─── API ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
API_PORT=8000

# ─── Gemini (AI Companion) ────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ─── Google Cloud (Voice — Sprint 7) ─────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ─── Redis (session / cache) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
